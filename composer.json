{
    "name": "filahq/statify-easy-widget",
    "description": "Build Filament stat widgets from Eloquent models with a fluent API.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "filament",
        "laravel",
        "widget",
        "stats",
        "eloquent"
    ],
    "suggest": {
        "filahq/statify": "Optional companion package if you want to expose these widgets through the Statify API."
    },
    "require": {
        "php": "^8.3",
        "filament/filament": "^5.0",
        "illuminate/support": "^12.0",
        "illuminate/database": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "FilaHQ\\StatifyEasyWidget\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "FilaHQ\\StatifyEasyWidget\\Tests\\": "tests/"
        }
    },
    "require-dev": {
        "pestphp/pest": "^3.8",
        "orchestra/testbench": "^10.0",
        "pestphp/pest-plugin-laravel": "^3.2"
    },
    "extra": {
        "laravel": {
            "providers": [
                "FilaHQ\\StatifyEasyWidget\\StatifyEasyWidgetServiceProvider"
            ]
        }
    }
}
